{
  "name": "erinjs-monorepo",
  "version": "1.2.4",
  "private": true,
  "license": "Apache-2.0",
  "description": "erin.js SDK monorepo",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:esm": "node scripts/test-esm-imports.mjs",
    "test:cjs": "node scripts/test-cjs-require.mjs",
    "test:load": "pnpm run test:esm && pnpm run test:cjs && pnpm run test:exports",
    "test:exports": "node scripts/test-package-exports.mjs",
    "test:smoke": "node scripts/test-smoke.mjs",
    "test:all": "pnpm run build && pnpm exec vitest run && pnpm run test:load && pnpm run test:smoke",
    "test:report": "pnpm run build && pnpm exec vitest run --reporter json --outputFile.json=test-results/results.json",
    "lint": "turbo run lint --filter=!@erinjs/docs",
    "lint:fix": "turbo run lint:fix --filter=!@erinjs/docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean && rm -rf node_modules",
    "generate:types": "pnpm exec tsx scripts/generate-types.ts",
    "generate:emoji": "pnpm exec tsx scripts/generate-emoji-shortcodes.ts",
    "generate:docs": "pnpm exec tsx scripts/generate-docs.ts",
    "generate:rag": "pnpm run generate:docs && pnpm exec tsx scripts/generate-ai-rag.ts",
    "docs:generate": "pnpm run build && pnpm run generate:docs",
    "docs:dev": "pnpm --filter @erinjs/docs dev",
    "docs:build": "pnpm run build && pnpm run generate:docs && pnpm --filter @erinjs/docs build",
    "docs:preview": "pnpm --filter @erinjs/docs preview",
    "docs:deploy": "pnpm run docs:build && wrangler deploy",
    "publish:packages": "node scripts/publish-ordered.js",
    "publish:packages:all": "pnpm run build && pnpm -r publish --no-git-checks --filter '!./examples'"
  },
  "devDependencies": {
    "@erinjs/builders": "workspace:*",
    "@erinjs/collection": "workspace:*",
    "@erinjs/core": "workspace:*",
    "@erinjs/rest": "workspace:*",
    "@erinjs/types": "workspace:*",
    "@erinjs/util": "workspace:*",
    "@erinjs/voice": "workspace:*",
    "@erinjs/ws": "workspace:*",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.0.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "minimatch": ">=10.2.3",
      "brace-expansion": ">=5.0.5",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.25.0"
    }
  }
}
